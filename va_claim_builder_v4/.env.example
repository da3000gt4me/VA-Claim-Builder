# Never commit real keys.
OPENAI_API_KEY=
XAI_API_KEY=
VCB_AI_PROVIDER=openai
VCB_OPENAI_MODEL=gpt-5
VCB_XAI_MODEL=grok-4.5
VCB_LOCAL_ONLY=false
VCB_MAX_INPUT_CHARS=45000
VCB_MONTHLY_BUDGET_USD=25
VCB_REDACT_IDENTIFIERS=true

# Parallel multi-agent mode
VCB_AI_MODE=ensemble
VCB_AI_ENSEMBLE=openai,xai
# Optional: openai or xai. Leave blank to require manual review of disagreements.
VCB_AI_ADJUDICATOR=
VCB_AI_MAX_CONCURRENCY=2
